{
  "name": "nextjs-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx,css,html,yml,yaml,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mdx,css,html,yml,yaml,scss}\"",
    "test": "jest",
    "test:unit": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "cypress run",
    "cypress:open": "cypress open",
    "perf:lhci": "lhci autorun --config=./lighthouserc.json",
    "perf:load": "artillery run artillery.config.yml",
    "perf:bundle": "next build && source-map-explorer \".next/static/chunks/*.js\" --html .sme-report.html || true",
    "db:seed": "tsx lib/db/seed.ts",
    "db:seed-users": "tsx lib/db/seed-users.ts",
    "db:seed-products": "tsx lib/db/seed-products.ts",
    "db:seed-parks": "tsx lib/db/seed-parks.ts",
    "db:seed-reviews": "tsx lib/db/seed-reviews.ts"
  },
  "dependencies": {
    "@next-auth/mongodb-adapter": "^1.1.3",
    "@prisma/client": "^6.18.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "eslint-config-prettier": "^10.1.8",
    "ioredis": "^5.8.2",
    "js-cookie": "^3.0.5",
    "lightningcss": "^1.30.2",
    "lucide-react": "0.548.0",
    "mongodb": "^6.20.0",
    "mongoose": "^8.19.2",
    "next": "16.0.0",
    "next-auth": "^4.24.12",
    "next-intl": "^4.4.0",
    "nodemailer": "^7.0.10",
    "prettier": "^3.6.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@lhci/cli": "^0.13.0",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.12",
    "@types/js-cookie": "^3.0.6",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "artillery": "^2.0.0-30",
    "autoprefixer": "^10.4.21",
    "cypress": "^13.13.2",
    "eslint": "^9",
    "eslint-config-next": "16.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.3.1",
    "postcss": "^8.5.6",
    "rtlcss": "^4.3.0",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5"
  }
}
