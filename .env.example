# Database
MONGODB_URI=your_mongodb_connection_string_here

# Redis
REDIS_URL=your_redis_url_here

# NextAuth.js
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Shopify
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Client-side uploads (required for admin image uploader)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
# Required for guide uploads to go to guideAssets (not skateparks). Create a separate unsigned preset with Folder = guideAssets.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_GUIDES=your_guideAssets_preset_name
# Required for event uploads to go to EventAssets folder. Create an unsigned preset with Folder = EventAssets (or eventAssets).
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_EVENTS=your_EventAssets_preset_name
# Optional: for skateparks uploads to go to skateparks folder only (preset with Folder = skateparks)
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_SKATEPARKS=skateparks_preset_name

# EmailJS
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
